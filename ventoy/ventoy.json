{
    "_comentario": [
        { "text": "Tema desarrollado por arc3uz para la iniciativa CPU UC," },
        { "text": "Basado en el ecosistema de Software Libre y con la intención de ser un tema ligero, moderno y funcional para Ventoy." }
        { "text": "https://github.com/arc3uz/CPU-UC-Ventoy-Theme.git" }
    ],
    
    "control": [
        { "VTOY_DEFAULT_MENU_MODE": "1" },
        { "VTOY_FILT_DOT_UNDERSCORE_FILE": "1" },
        { "VTOY_DEFAULT_SEARCH_ROOT": "/ISO" },
        { "VTOY_MENU_LANGUAGE": "es_ES" },
        { "VTOY_DEFAULT_KBD_LAYOUT": "QWERTY_ES" },
        { "VTOY_TREE_VIEW_MENU_STYLE": "0" }
        
    ],

    "theme": {
        "file": "/ventoy/theme/CPU_UC/theme.txt",
        "gfxmode": "1920x1080,1366x768,1280x720,1024x768",
        "display_mode": "GUI",
        "ventoy_color": "#ffffff",
        "ventoy_left": "150%",
        "ventoy_top": "150%",
        "fonts": [
            "/ventoy/theme/CPU_UC/hackb_18.pf2",
            "/ventoy/theme/CPU_UC/norwester_16.pf2",
            "/ventoy/theme/CPU_UC/norwester_20.pf2",
            "/ventoy/theme/CPU_UC/norwester_22.pf2"
        ]
    },

